# Grafana SMTP Configuration (For sending alerts)
GF_SMTP_ENABLED=true
GF_SMTP_HOST=smtp.gmail.com:587
GF_SMTP_USER=your-sender-email@gmail.com
GF_SMTP_PASSWORD=your-google-app-password
GF_SMTP_FROM_ADDRESS=your-sender-email@gmail.com
GF_SMTP_FROM_NAME=Grafana Lakehouse Alerts

# Alert Recipient Configuration (For receiving alerts)
SMTP_RECIPIENT=your-recipient-email@example.com
